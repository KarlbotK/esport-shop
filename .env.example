# =====================================================================
# ShopAgent — Environment Configuration Template
# =====================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control!
# =====================================================================

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/shop_agent?charset=utf8mb4

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=generate-a-random-64-char-string-here
JWT_EXPIRY_HOURS=24

# ─── DeepSeek AI API ──────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-real-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── QQ SMTP (for order confirmation emails) ────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-qq-number@qq.com
SMTP_PASSWORD=your-smtp-authorization-code

# ─── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
